{
  "name": "ziegs-on-a-mission-merch-store",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "dotenv -e .env.local -- next dev --webpack",
    "postinstall": "prisma generate",
    "build": "tsx scripts/build.ts",
    "typecheck": "tsc --noEmit --pretty false",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "db:push": "dotenv -e .env.local -- prisma db push",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "db:migrate:deploy": "node scripts/migrate-deploy.mjs",
    "db:migrate:deploy:direct": "dotenv -e .env.local -- prisma migrate deploy",
    "db:migrate:resolve": "node scripts/prisma-with-env.mjs migrate resolve",
    "db:execute:migration": "node scripts/prisma-with-env.mjs db execute --file prisma/migrations/20250308120000_add_product_status_and_extras/migration.sql --schema prisma/schema.prisma",
    "db:fix:production": "node scripts/apply-production-fix.mjs",
    "db:seed": "dotenv -e .env.local -- tsx prisma/seed.ts",
    "db:seed:admin": "dotenv -e .env.local -- tsx prisma/seed-admin.ts",
    "db:seed:mission-hub": "dotenv -e .env.local -- tsx prisma/seed-mission-hub-spaces.ts",
    "db:seed:mission-hub:production": "dotenv -o -e .env.production -- tsx prisma/seed-mission-hub-spaces.ts",
    "db:seed:blog-articles:production": "dotenv -o -e .env.production -- tsx scripts/seed-blog-articles-space.ts",
    "db:check:production": "dotenv -o -e .env.production -- tsx scripts/check-mission-hub-production.ts",
    "db:validate:env:local": "node scripts/validate-db-env.mjs .env.local",
    "db:validate:env:production": "node scripts/validate-db-env.mjs .env.production",
    "validate:supabase-storage": "node scripts/validate-supabase-storage-env.mjs .env.local",
    "check:newsletter-storage": "node scripts/check-newsletter-storage.mjs",
    "check:newsletter-db": "node scripts/check-newsletter-db.mjs",
    "db:migrate:deploy:production": "MIGRATE_ENV_FILE=.env.production node scripts/migrate-deploy.mjs",
    "db:migrate:status:production": "dotenv -o -e .env.production -- prisma migrate status",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "db:validate": "dotenv -e .env.local -- prisma validate",
    "test:order": "dotenv -e .env.local -- tsx scripts/test-order-flow.ts",
    "test:email": "tsx scripts/test-order-email.ts",
    "test:email:label": "tsx scripts/test-order-email-with-label.ts",
    "smoke:mission-hub-newsletter": "dotenv -e .env.local -- tsx scripts/smoke-mission-hub-newsletter.ts",
    "smoke:mission-hub-newsletter:production": "dotenv -o -e .env.production -- tsx scripts/smoke-mission-hub-newsletter.ts",
    "resend:emails": "tsx scripts/resend-order-emails.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.4",
    "@prisma/client": "^6.9.0",
    "@supabase/supabase-js": "^2.106.1",
    "@vercel/blob": "^2.3.1",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "next-auth": "^5.0.0-beta.25",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "resend": "^4.8.0",
    "server-only": "^0.0.1",
    "stripe": "^17.4.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prisma": "^6.9.0",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
