# Copy to .env and .env.local for local development. For Vercel, set these in Project → Settings → Environment Variables.
# See docs/go-live-checklist.md for Supabase + Vercel setup.

# Database (PostgreSQL). Both required for Prisma — do not swap these roles.
# Supabase (Zieg's project pattern):
#   DATABASE_URL = transaction pooler :6543 (runtime / Prisma queries)
#   DIRECT_URL     = direct db.<ref>.supabase.co :5432 (migrations on Vercel / when reachable)
# Local: `npm run db:migrate:deploy` auto-falls back to session pooler :5432 if direct host is blocked.
# Optional override: MIGRATE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-us-west-2.pooler.supabase.com:5432/postgres"
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-us-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres"
# Vercel Postgres (non-Supabase): POSTGRES_PRISMA_URL + POSTGRES_URL_NON_POOLING
AUTH_SECRET=""
NEXTAUTH_URL=""
# Public site URL for absolute links in dev/tools (optional if NEXTAUTH_URL is enough)
NEXT_PUBLIC_SITE_URL=""
# When set, /partner and /give primary CTAs open your processor; otherwise they link to /contact.
# NEXT_PUBLIC_GIVING_MONTHLY_URL="https://..."
# NEXT_PUBLIC_GIVING_ONE_TIME_URL="https://..."
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# Stripe webhook: required for order creation + confirmation emails. Get from Stripe Dashboard → Webhooks.
STRIPE_WEBHOOK_SECRET=""
# Printify: catalog sync + fulfillment. Token can be PRINTIFY_API_TOKEN or PRINTIFY_API_KEY.
PRINTIFY_API_KEY=""
PRINTIFY_SHOP_ID=""

# Local: NEXTAUTH_URL="http://localhost:3000"
# Vercel production: NEXTAUTH_URL="https://ziegsonamission.com"

# Mission Hub: set to "1" to allow legacy visitor_key-only profiles to comment (default: account required).
# MISSION_HUB_ALLOW_VISITOR_COMMENTS=""

# Supabase Storage — Mission Hub (community-media) + Newsletter Builder (newsletter-assets).
# Validate: npm run validate:supabase-storage
# Docs: docs/supabase-community-media.md, docs/supabase-newsletter-assets.md
# NEXT_PUBLIC_SUPABASE_URL="https://YOUR_REF.supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY=""  # legacy anon JWT (eyJ...) — optional for server uploads
# SUPABASE_SERVICE_ROLE_KEY=""  # server only — legacy service_role JWT (eyJ...), NOT sb_secret_...

# Vercel Blob (merch product + site-copy image uploads). Mission Hub + newsletters use Supabase above.
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Resend: order confirmation emails + Mission Hub notification emails (when enabled below).
# Domain ziegsonamission.com must be verified in Resend.
RESEND_API_KEY=""

# Mission Hub notification email (Circle-like; not Mail Suite). Default off.
# ENABLE_MISSION_HUB_EMAIL_NOTIFICATIONS="true"
# Emergency stabilization: blog_published + urgent_prayer_request fan-out (default off).
# MISSION_HUB_ADVANCED_NOTIFICATIONS_ENABLED="true"
# MISSION_HUB_FROM_EMAIL="hello@ziegsonamission.com"
# MISSION_HUB_FROM_NAME="Zieg's on a Mission"
# MISSION_HUB_REPLY_TO_EMAIL="jeremy@ziegsonamission.com"

# Weekly digest cron (Friday scheduled send). Default off — enable only in production when ready.
# MISSION_HUB_WEEKLY_DIGEST_CRON_ENABLED="true"
# CRON_SECRET=""  # Vercel Cron sends Authorization: Bearer <CRON_SECRET>

# Admin bootstrap (npm run db:seed:admin). Upserts owners in src/lib/admin-users.ts (role ADMIN in DB).
# ADMIN_EMAIL=""  # optional override for Jeremy's email only (legacy)
# ADMIN_PASSWORD=""  # Jeremy — if unset, seed uses embedded dev hash (rotate in production)
# ADMIN_PASSWORD_LINDSAY=""  # Lindsay — required to set/rotate her password via seed
#
# Production-only: POST /api/admin/setup-credentials with Authorization: Bearer <token> and JSON
# {"password":"..."} to create/update admin when you cannot run seed against prod. Remove after use.
# ADMIN_SETUP_TOKEN=""
# Temporary: set AUTH_DEBUG=1 on Vercel to log credential-failure reasons (no PII) in function logs.
# AUTH_DEBUG=""
# Migrations are not run during `npm run build` / Vercel deploy. Apply schema changes explicitly:
#   npm run db:migrate        (local dev — creates + applies)
#   npm run db:migrate:deploy (production/staging — apply pending only)

# Mission Hub `community_spaces` + `community_posts` use the same Supabase Postgres as Prisma.
# RLS: anon/authenticated may SELECT published posts in published spaces; Prisma admin manages writes.

# Optional: overrides default in src/data/legal-config.ts
# EMAIL_FROM="Zieg's on a Mission Merch <orders@ziegsonamission.com>"
