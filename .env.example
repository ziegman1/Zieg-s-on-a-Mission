# Copy to .env and .env.local for local development. For Vercel, set these in Project → Settings → Environment Variables.
# See docs/go-live-checklist.md for Supabase + Vercel setup.

# Database (PostgreSQL). Both required for Prisma — do not omit DIRECT_URL.
# DATABASE_URL = pooler (port 6543 for Supabase); DIRECT_URL = direct (port 5432) for migrations.
# Vercel Postgres: use POSTGRES_PRISMA_URL and POSTGRES_URL_NON_POOLING (build script maps these).
# Neon/Supabase: set DATABASE_URL and DIRECT_URL directly.
DATABASE_URL="postgresql://user:pass@host:5432/db?sslmode=require"
DIRECT_URL="postgresql://user:pass@host:5432/db?sslmode=require"
AUTH_SECRET=""
NEXTAUTH_URL=""
# Public site URL for absolute links in dev/tools (optional if NEXTAUTH_URL is enough)
NEXT_PUBLIC_SITE_URL=""
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# Stripe webhook: required for order creation + confirmation emails. Get from Stripe Dashboard → Webhooks.
STRIPE_WEBHOOK_SECRET=""
# Printify: catalog sync + fulfillment. Token can be PRINTIFY_API_TOKEN or PRINTIFY_API_KEY.
PRINTIFY_API_KEY=""
PRINTIFY_SHOP_ID=""

# Local: NEXTAUTH_URL="http://localhost:3000"
# Vercel production: NEXTAUTH_URL="https://ziegsonamission.com"

# Vercel Blob (admin product image uploads). Get token from Vercel → Storage → Blob.
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Resend: order confirmation emails. Get from resend.com. Domain ziegsonamission.com must be verified.
RESEND_API_KEY=""

# Admin bootstrap (prisma seed / seed-admin). Email defaults to jziegenhorn@teamexpansion.org if unset.
# ADMIN_EMAIL="jziegenhorn@teamexpansion.org"
# ADMIN_PASSWORD=""  # if set, seed hashes this; if empty, seed uses embedded default hash in prisma/seed.ts
#
# Production-only: POST /api/admin/setup-credentials with Authorization: Bearer <token> and JSON
# {"password":"..."} to create/update admin when you cannot run seed against prod. Remove after use.
# ADMIN_SETUP_TOKEN=""
# Temporary: set AUTH_DEBUG=1 on Vercel to log credential-failure reasons (no PII) in function logs.
# AUTH_DEBUG=""
# Emergency only: allow `npm run build` to continue if migrate deploy fails (risks RLS/schema drift).
# SKIP_PRISMA_MIGRATE=""

# Optional: overrides default in src/data/legal-config.ts
# EMAIL_FROM="Zieg's on a Mission Merch <orders@ziegsonamission.com>"
