// Zieg's on a Mission Merch — Prisma schema
// Multi-supplier fulfillment: dropship (Printify) + self-fulfilled

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  CUSTOMER
  STAFF
  ADMIN
}

enum FulfillmentType {
  dropship
  self_fulfilled
}

enum OrderStatus {
  PENDING
  PAID
  FULFILLING
  SHIPPED
  COMPLETE
  CANCELLED
}

enum FulfillmentStatus {
  PENDING
  SUBMITTED
  PROCESSING
  SHIPPED
  DELIVERED
  FAILED
}

enum ProviderType {
  PRINTIFY
  GENERIC
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  emailVerified DateTime?
  name          String?
  image         String?
  passwordHash  String?
  role          UserRole  @default(CUSTOMER)
  communityNotificationPrefs Json? @map("community_notification_prefs")
  /** Partnership onboarding segments (ministry updates, prayer team, etc.) */
  communityEngagementPrefs Json? @map("community_engagement_prefs")
  accounts      Account[]
  sessions      Session[]
  communityMember CommunityMemberRecord?
  communityPostsAuthored CommunityPostRecord[] @relation("CommunityPostAuthor")
  notificationsReceived CommunityNotificationRecord[] @relation("NotificationRecipient")
  notificationsSent     CommunityNotificationRecord[] @relation("NotificationActor")
  missionHubEmailDeliveries MissionHubEmailDeliveryRecord[]
  emailSuppressions         EmailSuppressionRecord[]
  notificationPreferenceEvents NotificationPreferenceEventRecord[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

// ——— Catalog ———

model Collection {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  imageUrl    String?
  featured    Boolean   @default(false)
  products   ProductCollection[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id               String          @id @default(cuid())
  title            String
  slug             String          @unique
  description      String?
  shortDescription String?
  fulfillmentType  FulfillmentType
  providerId       String?
  published        Boolean         @default(false) // legacy; prefer status
  status           ProductStatus   @default(DRAFT)
  publishedAt      DateTime?
  featuredImage    String?
  featured         Boolean         @default(false)
  /** Color names in thumbnail order: ["Black","Navy","Maroon","Grey"] means thumbnail 0=Black, 1=Navy, etc. */
  colorOrder       Json?
  /** ProductImage id to show as primary on storefront; when set, this image is shown first. */
  primaryImageId   String?
  /** Tags for filtering/grouping: ["featured", "apparel", "drinkware"]. Featured tag = featured item; apparel/drinkware = category. */
  tags             Json?           @default("[]")
  /** Self-fulfilled only: when true, product shows as out of stock on storefront regardless of inventory. */
  markOutOfStock   Boolean         @default(false)
  /** When true, product card is faded with "Out of stock" watermark; product page viewable but add-to-cart disabled. */
  paused           Boolean         @default(false)
  /** When true, product card is faded with "Coming Soon" watermark; product page viewable but add-to-cart disabled. */
  comingSoon       Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  provider         Provider?       @relation(fields: [providerId], references: [id], onDelete: SetNull)
  variants         ProductVariant[]
  images           ProductImage[]
  collections      ProductCollection[]
  externalMappings ExternalProductMapping[]
}

model ProductCollection {
  productId    String
  collectionId String
  product     Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  @@id([productId, collectionId])
}

model ProductVariant {
  id           String   @id @default(cuid())
  productId    String
  sku          String?
  name         String?  // e.g. "Small / Red"
  priceCents   Int
  compareAtCents Int?
  options      Json?    // e.g. { "Size": "S", "Color": "Red" }
  sortOrder    Int      @default(0)
  active       Boolean  @default(true)
  imageOverride String?
  /** Printify/dropship only: when false, variant is out of stock at provider. Null = unknown/assume available. */
  printifyAvailable Boolean?
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventory   Inventory?
  externalMappings ExternalProductMapping[]
  orderItems  OrderItem[]
}

model ProductImage {
  id         String   @id @default(cuid())
  productId  String
  url        String
  alt        String?
  sortOrder  Int      @default(0)
  variantIds Json?    // Printify variant ids this image applies to
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// ——— Providers (dropship) ———

model Provider {
  id        String   @id @default(cuid())
  type      ProviderType
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true)
  products  Product[]
  settings  ProviderSetting[]
  fulfillments Fulfillment[]
}

model ProviderSetting {
  id         String   @id @default(cuid())
  providerId String
  key        String
  value      String   // encrypted at rest if sensitive; for v1 may use env + reference only
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  @@unique([providerId, key])
}

// ——— Shipping ———

// Single default address for admin to ship international orders from (Printify is US-only).
model DefaultFulfillmentAddress {
  id           String   @id @default(cuid())
  name         String?
  line1        String?
  line2        String?
  city         String?
  state        String?
  postalCode   String?
  country      String?  @default("US")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ShippingRate {
  id         String   @id @default(cuid())
  zoneType   String   @unique // "domestic_us" | "international"
  name       String
  priceCents Int
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ExternalProductMapping {
  id                String   @id @default(cuid())
  productId         String
  productVariantId  String
  externalProductId String  // e.g. printify product id
  externalVariantId String  // e.g. printify variant id
  product           Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  productVariant   ProductVariant  @relation(fields: [productVariantId], references: [id], onDelete: Cascade)
  @@unique([productId, productVariantId])
}

// ——— Inventory (self-fulfilled) ———

model Inventory {
  id        String   @id @default(cuid())
  variantId String   @unique
  quantity  Int      @default(0)
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
}

// ——— Cart (optional; client-side for v1) ———
// No Cart model for v1; can add later

// ——— Checkout (cart stored server-side to avoid Stripe metadata 500-char limit) ———
model PendingCheckoutCart {
  id               String   @id @default(cuid())
  stripeSessionId  String   @unique
  cartJson         String   // full cart for order creation after payment
  createdAt        DateTime @default(now())
}

// ——— Orders ———

model Order {
  id                String      @id @default(cuid())
  stripeSessionId   String?     @unique
  stripePaymentIntentId String?
  email             String
  status            OrderStatus @default(PENDING)
  totalCents        Int
  currency          String      @default("usd")
  shippingName      String?
  shippingLine1     String?
  shippingLine2     String?
  shippingCity      String?
  shippingState     String?
  shippingPostalCode String?
  shippingCountry   String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  items             OrderItem[]
  fulfillments      Fulfillment[]
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  variantId  String
  quantity   Int
  priceCents Int
  order      Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant    ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  fulfillments FulfillmentItem[]
}

// ——— Fulfillment ———

model Fulfillment {
  id               String           @id @default(cuid())
  orderId          String
  providerId       String?
  externalOrderId  String?          // e.g. Printify order id
  status           FulfillmentStatus @default(PENDING)
  order            Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider         Provider?        @relation(fields: [providerId], references: [id], onDelete: SetNull)
  items            FulfillmentItem[]
  shipments        Shipment[]
}

model FulfillmentItem {
  id            String   @id @default(cuid())
  fulfillmentId String
  orderItemId   String
  quantity      Int
  fulfillment   Fulfillment @relation(fields: [fulfillmentId], references: [id], onDelete: Cascade)
  orderItem     OrderItem  @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  @@unique([fulfillmentId, orderItemId])
}

model Shipment {
  id             String   @id @default(cuid())
  fulfillmentId  String
  carrier        String?
  trackingNumber String?
  shippedAt      DateTime?
  fulfillment    Fulfillment @relation(fields: [fulfillmentId], references: [id], onDelete: Cascade)
}

// ——— Analytics (storefront traffic) ———
model PageView {
  id        String   @id @default(cuid())
  path      String   // e.g. /shop, /product/foo
  referrer  String?  // full referrer URL or null
  visitorId String?  // hashed identifier for unique visitor count (privacy-safe)
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([path])
}

// ——— Editable storefront copy (admin) ———
model SiteCopy {
  id        String   @id @default("default")
  payload   Json     @default("{}")
  updatedAt DateTime @updatedAt
}

/// Visual site builder sections (storefront pages).
model SitePageSection {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pageKey     String   @map("page_key")
  sectionKey  String   @map("section_key")
  sectionType String   @map("section_type")
  label       String   @default("")
  visible     Boolean  @default(true)
  sortOrder   Int      @default(0) @map("sort_order")
  content     Json     @default("{}")
  settings    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([pageKey, sectionKey])
  @@index([pageKey, sortOrder])
  @@map("site_page_sections")
}

// ——— Mission Hub community (Supabase `community_spaces` + RLS) ———
model CommunitySpaceRecord {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String
  slug        String   @unique
  description String?
  icon        String?
  coverImageUrl String? @map("cover_image_url")
  featured    Boolean  @default(false)
  settings    Json     @default("{}")
  spaceType   String   @default("standard") @map("space_type")
  welcomeMessage String? @map("welcome_message")
  engagementPrompt String? @map("engagement_prompt")
  themeMood   String?  @map("theme_mood")
  allowComments Boolean @default(true) @map("allow_comments")
  allowReactions Boolean @default(true) @map("allow_reactions")
  allowMemberPosts Boolean @default(false) @map("allow_member_posts")
  requirePostApproval Boolean @default(false) @map("require_post_approval")
  allowVoiceMessages Boolean @default(false) @map("allow_voice_messages")
  showWelcomeMessage Boolean @default(true) @map("show_welcome_message")
  pinWelcomeMessage Boolean @default(true) @map("pin_welcome_message")
  status      String   @default("draft")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  posts       CommunityPostRecord[]

  @@index([status, sortOrder])
  @@index([spaceType])
  @@map("community_spaces")
}

model CommunityPostRecord {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  spaceId       String    @map("space_id") @db.Uuid
  authorUserId  String?   @map("author_user_id")
  title         String?
  body          String
  excerpt       String?
  postType      String    @default("update") @map("post_type")
  status        String    @default("draft")
  coverImageUrl String?   @map("cover_image_url")
  sourceKind    String?   @map("source_kind")
  sourceId      String?   @map("source_id")
  metadata      Json      @default("{}")
  publishedAt   DateTime? @map("published_at") @db.Timestamptz(6)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  space      CommunitySpaceRecord       @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  authorUser User?                      @relation("CommunityPostAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)
  reactions  CommunityPostReactionRecord[]
  comments   CommunityPostCommentRecord[]
  notifications CommunityNotificationRecord[]

  @@unique([sourceKind, sourceId, spaceId])
  @@index([spaceId, status])
  @@index([status, publishedAt])
  @@index([authorUserId])
  @@map("community_posts")
}

model CommunityPostReactionRecord {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  postId       String   @map("post_id") @db.Uuid
  reactionType String   @map("reaction_type")
  visitorKey   String   @map("visitor_key")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  post CommunityPostRecord @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, visitorKey, reactionType])
  @@index([postId])
  @@index([reactionType])
  @@index([visitorKey])
  @@map("community_post_reactions")
}

model CommunityMemberRecord {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String?   @unique @map("user_id")
  firstName       String    @map("first_name")
  lastName        String    @map("last_name")
  displayName     String?   @map("display_name")
  bio             String?
  email           String?   @unique
  profileImageUrl String?   @map("profile_image_url")
  visitorKey      String?   @unique @map("visitor_key")
  status          String    @default("active")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  user     User?                        @relation(fields: [userId], references: [id], onDelete: SetNull)
  comments CommunityPostCommentRecord[]
  notificationsActed CommunityNotificationRecord[]
  notificationPreferenceEvents NotificationPreferenceEventRecord[]

  @@index([status])
  @@index([createdAt])
  @@index([userId])
  @@map("community_members")
}

model CommunityPostCommentRecord {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  postId          String    @map("post_id") @db.Uuid
  parentCommentId String?   @map("parent_comment_id") @db.Uuid
  visitorKey      String    @map("visitor_key")
  memberId        String?   @map("member_id") @db.Uuid
  displayName     String?   @map("display_name")
  body            String
  status          String    @default("published")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  post          CommunityPostRecord            @relation(fields: [postId], references: [id], onDelete: Cascade)
  parentComment CommunityPostCommentRecord?    @relation("CommentReplies", fields: [parentCommentId], references: [id], onDelete: Cascade)
  replies       CommunityPostCommentRecord[]   @relation("CommentReplies")
  member        CommunityMemberRecord?         @relation(fields: [memberId], references: [id], onDelete: SetNull)
  notifications CommunityNotificationRecord[]

  @@index([postId])
  @@index([parentCommentId])
  @@index([visitorKey])
  @@index([memberId])
  @@index([status])
  @@index([createdAt])
  @@map("community_post_comments")
}

model CommunityNotificationRecord {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  recipientUserId String?   @map("recipient_user_id")
  actorUserId     String?   @map("actor_user_id")
  actorMemberId   String?   @map("actor_member_id") @db.Uuid
  postId          String?   @map("post_id") @db.Uuid
  commentId       String?   @map("comment_id") @db.Uuid
  type            String
  title           String
  body            String?
  readAt          DateTime? @map("read_at") @db.Timestamptz(6)
  dedupeKey       String?   @map("dedupe_key")
  metadata        Json      @default("{}")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  recipientUser User?                        @relation("NotificationRecipient", fields: [recipientUserId], references: [id], onDelete: Cascade)
  actorUser     User?                        @relation("NotificationActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  actorMember   CommunityMemberRecord?       @relation(fields: [actorMemberId], references: [id], onDelete: SetNull)
  post          CommunityPostRecord?         @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment       CommunityPostCommentRecord?  @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([recipientUserId, dedupeKey])
  @@index([recipientUserId])
  @@index([recipientUserId, readAt])
  @@index([createdAt])
  @@map("community_notifications")
}

model MissionHubEmailDeliveryRecord {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  recipientUserId  String    @map("recipient_user_id")
  recipientEmail   String    @map("recipient_email")
  notificationKind String    @map("notification_kind")
  dedupeKey        String    @map("dedupe_key")
  status           String    @default("pending")
  resendMessageId  String?   @map("resend_message_id")
  errorMessage     String?   @map("error_message")
  metadata         Json      @default("{}")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  sentAt           DateTime? @map("sent_at") @db.Timestamptz(6)

  recipientUser User @relation(fields: [recipientUserId], references: [id], onDelete: Cascade)

  @@unique([recipientUserId, dedupeKey])
  @@index([dedupeKey])
  @@index([status, createdAt])
  @@map("mission_hub_email_deliveries")
}

/** Address-level email suppressions (Mission Hub scope — separate from Mail Suite). */
model EmailSuppressionRecord {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email     String
  /** mission_hub | all — Mail Suite uses a separate system */
  scope     String   @default("mission_hub")
  reason    String
  userId    String?  @map("user_id")
  metadata  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([email, scope])
  @@index([email])
  @@index([scope])
  @@map("email_suppressions")
}

/** Audit log for Mission Hub notification preference and suppression changes. */
model NotificationPreferenceEventRecord {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String   @map("user_id")
  memberId      String?  @map("member_id") @db.Uuid
  email         String
  eventType     String   @map("event_type")
  /// user | admin | system | webhook
  actorType     String   @map("actor_type")
  actorUserId   String?  @map("actor_user_id")
  previousPrefs Json?    @map("previous_prefs")
  nextPrefs     Json?    @map("next_prefs")
  metadata      Json     @default("{}")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user   User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  member CommunityMemberRecord? @relation(fields: [memberId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@index([eventType, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@index([email])
  @@map("notification_preference_events")
}

model CommunityHubSettingsRecord {
  id              String   @id @default("default")
  title           String?
  tagline         String?
  logoUrl         String?  @map("logo_url")
  coverImageUrl   String?  @map("cover_image_url")
  welcomeText     String?  @map("welcome_text")
  invitationTitle String?  @map("invitation_title")
  invitationBody  String?  @map("invitation_body")
  welcomePostPath String?  @map("welcome_post_path")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("community_hub_settings")
}

enum BlogPostStatus {
  DRAFT
  PUBLISHED
}

model BlogPost {
  id               String         @id @default(cuid())
  title            String
  slug             String         @unique
  excerpt          String         @default("")
  body             String         @default("")
  featuredImageUrl String?        @map("featured_image_url")
  featuredImageAlt String         @default("") @map("featured_image_alt")
  status           BlogPostStatus @default(DRAFT)
  publishedAt      DateTime?      @map("published_at") @db.Timestamptz(6)
  createdAt        DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([status, publishedAt(sort: Desc)])
  @@map("blog_posts")
}

enum NewsletterStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model NewsletterBrandSettingsRecord {
  id                                String   @id @default("default")
  defaultHeaderImageUrl             String?  @map("default_header_image_url")
  headerAltText                     String   @default("") @map("header_alt_text")
  defaultFooterImageUrl             String?  @map("default_footer_image_url")
  footerAltText                     String   @default("") @map("footer_alt_text")
  brandBackgroundColor              String   @default("#F7F3EB") @map("brand_background_color")
  accentColor                       String   @default("#D4E8F5") @map("accent_color")
  lineAccentColor                   String   @default("#B8D4E8") @map("line_accent_color")
  defaultFooterText                 String   @default("") @map("default_footer_text")
  defaultCtaLabel                   String   @default("") @map("default_cta_label")
  defaultCtaUrl                     String   @default("") @map("default_cta_url")
  useDefaultHeaderForNew            Boolean  @default(true) @map("use_default_header_for_new")
  useDefaultFooterImageOnNewNewsletters Boolean @default(true) @map("use_default_footer_image_on_new")
  updatedAt                         DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("newsletter_brand_settings")
}

model Newsletter {
  id               String           @id @default(cuid())
  title            String
  subtitle         String           @default("")
  slug             String           @unique
  issueDate        DateTime?        @map("issue_date") @db.Timestamptz(6)
  headerImageUrl   String?          @map("header_image_url")
  useDefaultBrandedHeader Boolean   @default(true) @map("use_default_branded_header")
  featuredImageUrl String?          @map("featured_image_url")
  excerpt          String           @default("")
  body             String           @default("")
  bodyBlocks       Json             @default("[]") @map("body_blocks")
  ctaLabel              String           @default("") @map("cta_label")
  ctaUrl                String           @default("") @map("cta_url")
  ctaAlign              String           @default("center") @map("cta_align")
  footerImageUrl        String?          @map("footer_image_url")
  footerAltText         String           @default("") @map("footer_alt_text")
  useDefaultFooterImage Boolean          @default(true) @map("use_default_footer_image")
  seoTitle              String           @default("") @map("seo_title")
  seoDescription   String           @default("") @map("seo_description")
  status           NewsletterStatus @default(DRAFT)
  publishedAt      DateTime?        @map("published_at") @db.Timestamptz(6)
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([status, publishedAt(sort: Desc)])
  @@index([status, issueDate(sort: Desc)])
  @@map("newsletters")
}
